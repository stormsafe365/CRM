{
  "name": "stormsafe-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "StormSafe Steel CRM",
  "author": "StormSafe Steel",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "sync:builder": "node scripts/sync-builder.mjs",
    "electron": "electron .",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3001 && electron .\"",
    "app:preview": "npm run build && cross-env ELECTRON_SERVE_DIST=1 electron .",
    "app:build": "npm run build && electron-builder",
    "build:layout": "node scripts/build-layout.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.stormsafe.crm",
    "productName": "StormSafe CRM",
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "StormSafe CRM"
    }
  }
}
